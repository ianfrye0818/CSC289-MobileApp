{
  "name": "csc289mobile",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "engines": {
    "node": ">=22.0.0"
  },
  "packageManager": "npm@11.0.0",
  "scripts": {
    "dev": "expo start",
    "dev:concurrent": "concurrently -n app,server -c blue,green \"pnpm run start\" \"pnpm -C server run dev\"",
    "start": "expo start",
    "start:clear": "expo start --clear",
    "reset-project": "node ./scripts/reset-project.js",
    "eas:dev:android": "eas build --platform android --profile development",
    "eas:dev:ios": "eas build --platform ios --profile development",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "lint": "expo lint",
    "typecheck": "tsc --noEmit",
    "gen:api": "openapi-typescript http://localhost:3000/api/swagger/json -o ./types/types.generated.ts"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.0.3",
