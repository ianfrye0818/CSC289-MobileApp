    "@rn-primitives/portal": "^1.3.0",
    "@rn-primitives/select": "^1.2.0",
    "@rn-primitives/slot": "^1.2.0",
    "@rn-primitives/tabs": "^1.2.0",
    "@tanstack/react-query": "^5.91.3",
